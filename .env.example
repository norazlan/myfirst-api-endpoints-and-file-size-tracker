# Application port
APP_PORT=3000

# Storage limit in bytes (default: 1GB = 1073741824)
STORAGE_LIMIT=1073741824

# Maximum total API requests allowed (default: 1000)
REQUEST_LIMIT=1000

# Directory for uploaded files
UPLOAD_DIR=./uploads

# SQLite database file path
DB_PATH=./metering.db

# Interval (in seconds) to flush in-memory counters to DB
FLUSH_INTERVAL=30
